# OAuth Configuration - Development
VITE_GOOGLE_CLIENT_ID=933163961386-8974vfjfd3cjn3ti4mfdr26dama37rvc.apps.googleusercontent.com
VITE_REDIRECT_URI=http://localhost:3000/auth/callback

# OAuth Configuration - Production (uncomment for production)
# VITE_GOOGLE_CLIENT_ID=your_prod_google_client_id_here.apps.googleusercontent.com
# VITE_REDIRECT_URI=https://yourdomain.com/auth/callback

# API Configuration
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_SERVER_URL=/uploads

VITE_API_URL=http://localhost:8080/api/v1
VITE_APP_NAME=Mustody Platform
VITE_APP_VERSION=1.0.0
# Docs site (mustody-project-doc) — local Next.js dev server
VITE_DOCS_URL=http://localhost:3001
# Optional path prefix when docs are proxied (e.g. /docs on mustody.com)
VITE_DOCS_BASE_PATH=
# Set true when docs are served from the same origin as the app (no new tab)
# VITE_DOCS_SAME_ORIGIN=true

# Production (subdomain — recommended):
# VITE_DOCS_URL=https://docs.mustody.com
# VITE_DOCS_BASE_PATH=

# Public site URL (SEO: canonical, Open Graph, sitemap — use https://mustody.com in production)
VITE_SITE_URL=https://mustody.com
